/* ======================================================================
   DLM | دلم — قواعد أمان Firebase Storage (storage.rules)
   ======================================================================
   كيفية النشر:
   Firebase Console → Storage → Rules → الصق هذا الملف → Publish
   أو عبر CLI: firebase deploy --only storage:rules

   المبدأ:
   - القراءة عامة (لازمة لعرض صور الأغلفة لكل الزوار على الموقع).
   - الكتابة (رفع/حذف) محصورة بالأدمن المسجَّل فقط، مع تحقق من نوع الملف
     وحجمه الأقصى (4MB) كحماية إضافية على مستوى الخادم، لا الواجهة فقط.
   ====================================================================== */

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /covers/{poemId}/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && request.resource.size <= 4 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');

      allow delete: if request.auth != null;
    }

    // أي مسار آخر غير مذكور أعلاه: مرفوض بشكل افتراضي
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
